{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "extensions_SessionHostConfig_commandToExecute": {
            "type": "SecureString"
        },
        "virtualMachines_vmetf1tuse0001_name": {
            "defaultValue": "vmetf1tuse0001",
            "type": "String"
        },
        "networkInterfaces_nic_01_vmetf1tuse0001_name": {
            "defaultValue": "nic-01-vmetf1tuse0001",
            "type": "String"
        },
        "applicationSecurityGroups_asg_etf1_test_use_001_name": {
            "defaultValue": "asg-etf1-test-use-001",
            "type": "String"
        },
        "virtualNetworks_vnet_etf1_test_use_001_externalid": {
            "defaultValue": "/subscriptions/bd67233d-38af-45db-a98e-a10a2b443d8d/resourceGroups/rg-avd-etf1-test-use-network/providers/Microsoft.Network/virtualNetworks/vnet-etf1-test-use-001",
            "type": "String"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Network/applicationSecurityGroups",
            "apiVersion": "2024-07-01",
            "name": "[parameters('applicationSecurityGroups_asg_etf1_test_use_001_name')]",
            "location": "eastus",
            "tags": {
                "cm-resource-parent": "/subscriptions/bd67233d-38af-45db-a98e-a10a2b443d8d/resourceGroups/rg-avd-etf1-test-use-service-objects/providers/Microsoft.DesktopVirtualization/hostpools/vdpool-etf1-test-use-001",
                "Environment": "Test",
                "ServiceWorkload": "AVD",
                "CreationTimeUTC": "20260220T165154Z"
            },
            "properties": {}
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2024-11-01",
            "name": "[parameters('virtualMachines_vmetf1tuse0001_name')]",
            "location": "eastus",
            "dependsOn": [
                "[resourceId('Microsoft.Network/networkInterfaces', parameters('networkInterfaces_nic_01_vmetf1tuse0001_name'))]"
            ],
            "tags": {
                "cm-resource-parent": "/subscriptions/bd67233d-38af-45db-a98e-a10a2b443d8d/resourceGroups/rg-avd-etf1-test-use-service-objects/providers/Microsoft.DesktopVirtualization/hostpools/vdpool-etf1-test-use-001",
                "Environment": "Test",
                "ServiceWorkload": "AVD",
                "CreationTimeUTC": "20260220T165154Z"
            },
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "hardwareProfile": {
                    "vmSize": "Standard_D2ps_v6"
                },
                "additionalCapabilities": {
                    "ultraSSDEnabled": false
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "MicrosoftWindowsDesktop",
                        "offer": "windows-11",
                        "sku": "win11-24h2-avd",
                        "version": "latest"
                    },
                    "osDisk": {
                        "osType": "Windows",
                        "name": "[concat(parameters('virtualMachines_vmetf1tuse0001_name'), '-disk-os-01')]",
                        "createOption": "FromImage",
                        "caching": "ReadWrite",
                        "managedDisk": {
                            "storageAccountType": "Premium_LRS",
                            "id": "[resourceId('Microsoft.Compute/disks', concat(parameters('virtualMachines_vmetf1tuse0001_name'), '-disk-os-01'))]"
                        },
                        "deleteOption": "Delete",
                        "diskSizeGB": 127
                    },
                    "dataDisks": [],
                    "diskControllerType": "NVMe"
                },
                "osProfile": {
                    "computerName": "[parameters('virtualMachines_vmetf1tuse0001_name')]",
                    "adminUsername": "etfadmin",
                    "windowsConfiguration": {
                        "provisionVMAgent": true,
                        "enableAutomaticUpdates": true,
                        "patchSettings": {
                            "patchMode": "AutomaticByOS",
                            "assessmentMode": "ImageDefault"
                        },
                        "timeZone": "Eastern Standard Time"
                    },
                    "secrets": [],
                    "allowExtensionOperations": true,
                    "requireGuestProvisionSignal": true
                },
                "securityProfile": {
                    "uefiSettings": {
                        "secureBootEnabled": true,
                        "vTpmEnabled": true
                    },
                    "securityType": "TrustedLaunch"
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', parameters('networkInterfaces_nic_01_vmetf1tuse0001_name'))]",
                            "properties": {
                                "primary": true,
                                "deleteOption": "Delete"
                            }
                        }
                    ]
                },
                "diagnosticsProfile": {
                    "bootDiagnostics": {
                        "enabled": false
                    }
                },
                "licenseType": "Windows_Client",
                "priority": "Regular"
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines/extensions",
            "apiVersion": "2024-11-01",
            "name": "[concat(parameters('virtualMachines_vmetf1tuse0001_name'), '/MicrosoftAntiMalware')]",
            "location": "eastus",
            "dependsOn": [
                "[resourceId('Microsoft.Compute/virtualMachines', parameters('virtualMachines_vmetf1tuse0001_name'))]"
            ],
            "properties": {
                "autoUpgradeMinorVersion": true,
                "publisher": "Microsoft.Azure.Security",
                "type": "IaaSAntimalware",
                "typeHandlerVersion": "1.3",
                "settings": {
                    "AntimalwareEnabled": true,
                    "RealtimeProtectionEnabled": "true",
                    "ScheduledScanSettings": {
                        "isEnabled": "true",
                        "day": "7",
                        "time": "120",
                        "scanType": "Quick"
                    },
                    "Exclusions": {
                        "Extensions": "*.vhd;*.vhdx",
                        "Paths": "\"%ProgramFiles%\\FSLogix\\Apps\\frxdrv.sys;%ProgramFiles%\\FSLogix\\Apps\\frxccd.sys;%ProgramFiles%\\FSLogix\\Apps\\frxdrvvt.sys;%TEMP%\\*.VHD;%TEMP%\\*.VHDX;%Windir%\\TEMP\\*.VHD;%Windir%\\TEMP\\*.VHDX;\\\\stfsletf1tvxs.file.core.windows.net\\fslogix-pc-etf1-test-use-001\\*\\*.VHD;\\\\stfsletf1tvxs.file.core.windows.net\\fslogix-pc-etf1-test-use-001\\*\\*.VHDX",
                        "Processes": "%ProgramFiles%\\FSLogix\\Apps\\frxccd.exe;%ProgramFiles%\\FSLogix\\Apps\\frxccds.exe;%ProgramFiles%\\FSLogix\\Apps\\frxsvc.exe"
                    }
                }
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines/extensions",
            "apiVersion": "2024-11-01",
            "name": "[concat(parameters('virtualMachines_vmetf1tuse0001_name'), '/SessionHostConfig')]",
            "location": "eastus",
            "dependsOn": [
                "[resourceId('Microsoft.Compute/virtualMachines', parameters('virtualMachines_vmetf1tuse0001_name'))]"
            ],
            "properties": {
                "autoUpgradeMinorVersion": true,
                "publisher": "Microsoft.Compute",
                "type": "CustomScriptExtension",
                "typeHandlerVersion": "1.10",
                "settings": {
                    "fileUris": [
                        "https://raw.githubusercontent.com/azure/avdaccelerator/main/workload/scripts/Set-SessionHostConfiguration.ps1"
                    ],
                    "commandToExecute": "[parameters('extensions_SessionHostConfig_commandToExecute')]"
                },
                "protectedSettings": {}
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-07-01",
            "name": "[parameters('networkInterfaces_nic_01_vmetf1tuse0001_name')]",
            "location": "eastus",
            "dependsOn": [
                "[resourceId('Microsoft.Network/applicationSecurityGroups', parameters('applicationSecurityGroups_asg_etf1_test_use_001_name'))]"
            ],
            "tags": {
                "cm-resource-parent": "/subscriptions/bd67233d-38af-45db-a98e-a10a2b443d8d/resourceGroups/rg-avd-etf1-test-use-service-objects/providers/Microsoft.DesktopVirtualization/hostpools/vdpool-etf1-test-use-001",
                "Environment": "Test",
                "ServiceWorkload": "AVD",
                "CreationTimeUTC": "20260220T165154Z"
            },
            "kind": "Regular",
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig01",
                        "id": "[concat(resourceId('Microsoft.Network/networkInterfaces', parameters('networkInterfaces_nic_01_vmetf1tuse0001_name')), '/ipConfigurations/ipconfig01')]",
                        "type": "Microsoft.Network/networkInterfaces/ipConfigurations",
                        "properties": {
                            "privateIPAddress": "10.10.1.4",
                            "privateIPAllocationMethod": "Dynamic",
                            "subnet": {
                                "id": "[concat(parameters('virtualNetworks_vnet_etf1_test_use_001_externalid'), '/subnets/snet-avd-etf1-test-use-001')]"
                            },
                            "primary": true,
                            "privateIPAddressVersion": "IPv4",
                            "applicationSecurityGroups": [
                                {
                                    "id": "[resourceId('Microsoft.Network/applicationSecurityGroups', parameters('applicationSecurityGroups_asg_etf1_test_use_001_name'))]"
                                }
                            ]
                        }
                    }
                ],
                "dnsSettings": {
                    "dnsServers": []
                },
                "enableAcceleratedNetworking": true,
                "enableIPForwarding": false,
                "disableTcpStateTracking": false,
                "nicType": "Standard",
                "auxiliaryMode": "None",
                "auxiliarySku": "None"
            }
        }
    ]
}